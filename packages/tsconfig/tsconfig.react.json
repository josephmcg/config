{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    /* If NOT transpiling with TypeScript: */
    "module": "preserve",
    "moduleResolution": "bundler",
    "noEmit": true,

    /* If your code runs in the DOM: */
    "lib": ["ESNext", "DOM", "DOM.Iterable"],

    /* React specific jazz: */
    "jsx": "preserve"
  }
}
